# Lucid — Hallucination Auditor for Self-Orchestrating AI Agents

# Application
APP_NAME=Lucid
APP_VERSION=0.1.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://lucid:lucid@postgres:5432/lucid
DATABASE_URL_SYNC=postgresql://lucid:lucid@postgres:5432/lucid

# Redis
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# LLM Providers (fill in your keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default model
DEFAULT_MODEL=gpt-4o

# Agent config
AGENT_MAX_STEPS=20
AGENT_STEP_TIMEOUT=60

# CORS (frontend dev server)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
